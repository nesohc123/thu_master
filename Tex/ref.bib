@article{10.1111/j.2517-6161.1966.tb00663.x,

    author = {Ruben, Harold},
    title = "{Some New Results on the Distribution of the Sample Correlation Coefficient}",
    journal = {Journal of the Royal Statistical Society: Series B (Methodological)},
    volume = {28},
    number = {3},
    pages = {513-525},
    year = {2018},
    month = {12},
    abstract = "{A simple approximate normalization for the correlation coefficient in normal samples is obtained which is shown to compare favourably with previous normalization approximations (the usual large-sample normalization, Fisher's hyperbolic tangent transformation and Hotelling's improvement of that transformation). A second approximation, based on F and valid for large n | ρ | (n = sample size, ρ = population correlation), is also obtained. The results follow from a representation of the correlation in normal samples as the ratio of a linear combination of a standardized normal deviate and a Xn-1 to a Xn-2, where the three latter variates are independent.}",
    issn = {0035-9246},
    doi = {10.1111/j.2517-6161.1966.tb00663.x},
    url = {https://doi.org/10.1111/j.2517-6161.1966.tb00663.x},
    eprint = {https://academic.oup.com/jrsssb/article-pdf/28/3/513/49094787/jrsssb\_28\_3\_513.pdf},
language = {English}
}

